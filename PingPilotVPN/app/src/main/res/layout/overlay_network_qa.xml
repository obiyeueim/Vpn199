<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_network_qa_overlay"
    android:elevation="12dp"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/qa_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:text="NETWORK QA · DRAG"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/qa_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Initializing native module…"
        android:textColor="#FFB8C4D8"
        android:textSize="12sp" />

    <Switch
        android:id="@+id/switch_latency"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Latency simulation · 300 ms"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp" />

    <Switch
        android:id="@+id/switch_packet_drop"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Packet drop simulation"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Debug-only controls. The hook affects UDP calls made by this APK process."
        android:textColor="#FF8795AA"
        android:textSize="11sp" />

    <Button
        android:id="@+id/button_close_overlay"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:text="Close overlay"
        android:textAllCaps="false" />

</LinearLayout>
