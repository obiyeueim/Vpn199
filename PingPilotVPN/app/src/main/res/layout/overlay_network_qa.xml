<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/qa_bubble"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:background="@drawable/bg_network_qa_bubble"
        android:elevation="14dp"
        android:gravity="center"
        android:text="QA"
        android:textColor="#FFFFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/qa_panel"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_network_qa_overlay"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/qa_drag_handle"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="NETWORK QA · DRAG"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/button_collapse_overlay"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="—"
                android:textColor="#FFFFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/qa_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Initializing native module…"
            android:textColor="#FFB8C4D8"
            android:textSize="12sp" />

        <Switch
            android:id="@+id/switch_latency"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Latency simulation · 300 ms"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />

        <Switch
            android:id="@+id/switch_packet_drop"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Packet drop simulation"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Debug-only controls. The hook affects UDP calls made by this APK process."
            android:textColor="#FF8795AA"
            android:textSize="11sp" />

        <Button
            android:id="@+id/button_close_overlay"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:text="Close overlay"
            android:textAllCaps="false" />
    </LinearLayout>

</FrameLayout>
